#!/usr/bin/env python3
"""gate-verifier — the broad immutable-boundary gate (the superset that includes gate-signal).

Denies a worker write to ANY verifier/immutable asset (TDD §14.1): signals/, rubric/, the hooks
themselves, the run budget, lattice.json, the kernel schemas, and the wiring (.claude/settings.json so a
wired worker cannot unwire its own gate). The rewritable side — spec/, pattern/, drafts, instance
artifacts — stays freely writable under normal hooks. This is the gate you wire in production; gate-signal
is the focused reward-hack subset, kept distinct because it is the load-bearing one.

Consent-wired as a PreToolUse(Write|Edit) hook in the worker loop; non-zero exit = DENY.

`--allow-verify` switches to the RUBRIC-ARCHITECT boundary (VERIFIER_AUTHOR): a cell's `verify.mjs` becomes
writable — for the verifier-author authoring the gate — while signals/, rubric/, the lattice/ledger, and the
wiring stay denied. The module worker is wired WITHOUT this flag, so it still cannot grade its own homework.

`--allow-refute` switches to the REFUTE-AUTHOR boundary (REFUTE_AUTHOR): the verify-spec (`coordination/verify-
spec/*`) becomes writable — for the autonomous refute-author authoring the behavioral oracle — while `verify.mjs`,
the refuter sidecars, signals/, rubric/, the lattice/ledger, the wiring, AND the product barrel stay denied.

`--allow-triage` switches to the TRIAGE-AUTHOR boundary (TRIAGE_AUTHOR): the triage proposals dir
(`coordination/triage/*`) becomes writable — for the autonomous ticket-triager turning a free-text prompt into a
bound, dispatchable ticket — while verify.mjs, the verify-spec, the refuters, signals/, rubric/, the lattice/ledger,
the run/ budget+posture perimeter, and the wiring all stay denied (pure judgment, zero authority over state). The
three flags are mutually exclusive (each producer writes exactly one surface); passing more than one is rejected.

Usage:  gate-verifier [--allow-verify | --allow-refute | --allow-triage] --hook | check <path> | selftest
Stdlib only; Python 3.8+.
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import _gates  # noqa: E402

if __name__ == "__main__":
    argv = sys.argv[1:]
    globs = _gates.VERIFIER
    _allows = [f for f in ("--allow-verify", "--allow-refute", "--allow-triage") if f in argv]
    if len(_allows) > 1:
        sys.stderr.write("gate-verifier: --allow-verify / --allow-refute / --allow-triage are mutually exclusive "
                         "(each producer writes exactly one surface — verify.mjs / verify-spec / triage proposal — "
                         "never two in the same dispatch)\n")
        sys.exit(2)
    if "--allow-verify" in argv:                       # the verifier-author may write verify.mjs (it IS the gate)
        globs = _gates.VERIFIER_AUTHOR
        argv = [a for a in argv if a != "--allow-verify"]
    elif "--allow-refute" in argv:                     # the refute-author may write the verify-spec (the oracle's source)
        globs = _gates.REFUTE_AUTHOR
        argv = [a for a in argv if a != "--allow-refute"]
    elif "--allow-triage" in argv:                     # the triage-author may write ONLY its proposal (judgment, no authority)
        globs = _gates.TRIAGE_AUTHOR
        argv = [a for a in argv if a != "--allow-triage"]
    sys.exit(_gates.run_path_gate("gate-verifier", globs, argv, "verifier/immutable asset"))
